title = {Efficient GPU Implementation of Affine Index Permutations on Arrays},
year = {2023},
isbn = {9798400702969},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
doi = {10.1145/3609024.3609411},
abstract = {Optimal usage of the memory system is a key element of fast GPU algorithms. Unfortunately many common algorithms fail in this regard despite exhibiting great regularity in memory access patterns. In this paper we propose efficient kernels to permute the elements of an array. We handle a class of permutations known as Bit Matrix Multiply Complement (BMMC) permutations, for which we design kernels of speed comparable to that of a simple array copy. This is a first step towards implementing a set of array combinators based on these permutations.},
booktitle = {Proceedings of the 11th ACM SIGPLAN International Workshop on Functional High-Performance and Numerical Computing},
pages = {15–28},
numpages = {14},
keywords = {GPU, data-parallelism, functional languages},
location = {Seattle, WA, USA},
